<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cannot_create_JO_for_inactive_client</fullName>
    <active>true</active>
    <errorConditionFormula>OR( ISPICKVAL(Client__r.Status__c, &apos;Inactive&apos;), ISPICKVAL(Client__r.Status__c, &apos;Blacklisted&apos;) )</errorConditionFormula>
    <errorDisplayField>Status__c</errorDisplayField>
    <errorMessage>Job orders cannot be created for Inactive or Blacklisted clients. Update the client status first.</errorMessage>
</ValidationRule>
