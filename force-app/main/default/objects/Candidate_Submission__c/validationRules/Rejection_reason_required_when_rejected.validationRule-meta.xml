<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rejection_reason_required_when_rejected</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Rejected&quot;),
    ISPICKVAL(Rejection_Reason__c, &quot;&quot;)
)</errorConditionFormula>
    <errorDisplayField>Rejection_Reason__c</errorDisplayField>
    <errorMessage>Please select a rejection reason before marking this submission as Rejected</errorMessage>
</ValidationRule>
