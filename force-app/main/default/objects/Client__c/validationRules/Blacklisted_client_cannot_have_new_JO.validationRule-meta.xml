<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Blacklisted_client_cannot_have_new_JO</fullName>
    <active>true</active>
    <errorConditionFormula>AND( ISPICKVAL(Status__c, &apos;Blacklisted&apos;), NOT(ISBLANK(Name)) )</errorConditionFormula>
    <errorMessage>This client is blacklisted. New records cannot be created. Contact your Account Manager.</errorMessage>
</ValidationRule>
